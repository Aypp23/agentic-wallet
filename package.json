{
  "name": "agentic-wallet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/patch-rpc-websockets-compat.mjs",
    "build": "npm run -ws --if-present build",
    "dev": "concurrently -n gateway,wallet,policy,agent,protocol,tx,audit,mcp \"npm run dev:api-gateway\" \"npm run dev:wallet-engine\" \"npm run dev:policy-engine\" \"npm run dev:agent-runtime\" \"npm run dev:protocol-adapters\" \"npm run dev:transaction-engine\" \"npm run dev:audit-observability\" \"npm run dev:mcp-server\"",
    "dev:wallet-engine": "npm run dev --workspace @agentic-wallet/wallet-engine",
    "dev:api-gateway": "npm run dev --workspace @agentic-wallet/api-gateway",
    "dev:cli": "npm run dev --workspace @agentic-wallet/cli",
    "cli": "npm run dev --workspace @agentic-wallet/cli --",
    "cli:start": "npm run start --workspace @agentic-wallet/cli --",
    "dev:transaction-engine": "npm run dev --workspace @agentic-wallet/transaction-engine",
    "dev:policy-engine": "npm run dev --workspace @agentic-wallet/policy-engine",
    "dev:agent-runtime": "npm run dev --workspace @agentic-wallet/agent-runtime",
    "dev:protocol-adapters": "npm run dev --workspace @agentic-wallet/protocol-adapters",
    "dev:audit-observability": "npm run dev --workspace @agentic-wallet/audit-observability",
    "dev:mcp-server": "npm run dev --workspace @agentic-wallet/mcp-server",
    "devnet:smoke": "tsx scripts/devnet-smoke.ts",
    "devnet:multi-agent": "tsx scripts/devnet-multi-agent.ts",
    "devnet:multi-agent:load": "tsx scripts/devnet-multi-agent-load.ts",
    "devnet:protocol-matrix": "tsx scripts/devnet-protocol-matrix.ts",
    "demo:judge": "tsx scripts/demo-judge.ts",
    "escrow:sync-id": "node scripts/escrow-sync-program-id.mjs",
    "escrow:build": "npm run escrow:sync-id && anchor build",
    "escrow:deploy:devnet": "node scripts/escrow-deploy-devnet.mjs",
    "kora:validate": "KORA_PRIVATE_KEY=${KORA_PRIVATE_KEY:-$PRIVATE_KEY} kora --config infrastructure/kora/kora.toml --rpc-url ${SOLANA_RPC_URL:-https://api.devnet.solana.com} config validate --signers-config infrastructure/kora/signers.toml",
    "kora:validate:rpc": "KORA_PRIVATE_KEY=${KORA_PRIVATE_KEY:-$PRIVATE_KEY} kora --config infrastructure/kora/kora.toml --rpc-url ${SOLANA_RPC_URL:-https://api.devnet.solana.com} config validate-with-rpc --signers-config infrastructure/kora/signers.toml",
    "kora:start": "KORA_PRIVATE_KEY=${KORA_PRIVATE_KEY:-$PRIVATE_KEY} kora --config infrastructure/kora/kora.toml --rpc-url ${SOLANA_RPC_URL:-https://api.devnet.solana.com} rpc start --signers-config infrastructure/kora/signers.toml --port 8080",
    "intent-runner": "tsx scripts/intent-runner.ts",
    "wallets": "tsx scripts/wallets.ts",
    "chaos:test": "tsx scripts/chaos-failure-injection.ts",
    "policy:migrate:test": "tsx scripts/policy-migration-check.ts",
    "adapter:migrate:test": "tsx scripts/adapter-migration-check.ts",
    "lint": "eslint . --max-warnings=0",
    "secret:scan": "tsx scripts/secret-scan.ts",
    "ci:check": "npm run secret:scan && npm run lint && npm run typecheck && npm run test && npm run build",
    "test": "npm run -ws --if-present test",
    "typecheck": "npm run -ws --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
